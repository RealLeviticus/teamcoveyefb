# Service-to-service protection (required in split mode)
EFB_REQUIRE_SERVICE_TOKEN=1
EFB_SERVICE_TOKEN=replace-with-long-random-token

# Do not allow client-supplied PSX host/port from public requests
EFB_ALLOW_CLIENT_PSX_TARGET=0

# Backend setup OAuth (Discord)
SETUP_DISCORD_CLIENT_ID=your-discord-app-client-id
SETUP_DISCORD_CLIENT_SECRET=your-discord-app-client-secret
SETUP_DISCORD_GUILD_ID=your-discord-server-id
SETUP_ALLOWED_ROLE_IDS=comma,separated,role,ids
SETUP_SESSION_SECRET=replace-with-a-long-random-secret
SETUP_BASE_URL=https://backend-api.teamcovey.org

# Fallback PSX target if no setup UI config has been saved yet
PSX_HOST=127.0.0.1
PSX_PORT=10747
PSX_REFERENCES_DIR=C:\Users\levis\OneDrive\Documents 1\Aerowinx\Developers

# Optional explicit config file location
# EFB_CONFIG_PATH=C:\ProgramData\TeamCoveyEFB\backend-config.json
