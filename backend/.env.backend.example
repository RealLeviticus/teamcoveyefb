# Service-to-service protection (required in split mode)
EFB_REQUIRE_SERVICE_TOKEN=1
EFB_SERVICE_TOKEN=replace-with-long-random-token

# Do not allow client-supplied PSX host/port from public requests
EFB_ALLOW_CLIENT_PSX_TARGET=0
# Do not allow client-supplied X32 host/port from public requests
EFB_ALLOW_CLIENT_X32_TARGET=0

# Backend setup OAuth (Discord)
SETUP_DISCORD_CLIENT_ID=your-discord-app-client-id
SETUP_DISCORD_CLIENT_SECRET=your-discord-app-client-secret
SETUP_DISCORD_GUILD_ID=your-discord-server-id
SETUP_ALLOWED_ROLE_IDS=comma,separated,role,ids
SETUP_SESSION_SECRET=replace-with-a-long-random-secret
SETUP_BASE_URL=https://backend-api.teamcovey.org
# Optional: remember backend setup login for this many days (default 30)
# SETUP_SESSION_TTL_DAYS=30

# Fallback PSX target if no setup UI config has been saved yet
PSX_HOST=127.0.0.1
PSX_PORT=10747
PSX_REFERENCES_DIR=C:\Users\levis\OneDrive\Documents 1\Aerowinx\Developers
X32_HOST=127.0.0.1
X32_PORT=10023

# PSX call panel monitor (buttons 1-6 + P)
EFB_CALL_MONITOR_ENABLED=1
EFB_CALL_COOLDOWN_SECONDS=20

# Optional route overrides (otherwise read from setup config callRoutes)
# EFB_CALL_ROUTE_1=
# EFB_CALL_ROUTE_2=
# EFB_CALL_ROUTE_3=
# EFB_CALL_ROUTE_4=
# EFB_CALL_ROUTE_5=
# EFB_CALL_ROUTE_6=
# EFB_CALL_ROUTE_P=0401 495 110

# Optional PSX call-panel button code overrides (defaults: 1=0, 2=1, ..., 6=5, P=6)
# EFB_CALL_PANEL_CODE_1=0
# EFB_CALL_PANEL_CODE_2=1
# EFB_CALL_PANEL_CODE_3=2
# EFB_CALL_PANEL_CODE_4=3
# EFB_CALL_PANEL_CODE_5=4
# EFB_CALL_PANEL_CODE_6=5
# EFB_CALL_PANEL_CODE_P=6

# Outbound call provider: twilio | webhook
EFB_CALL_PROVIDER=twilio

# Twilio provider settings
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Optional custom TwiML. Default says which call-panel button was pressed.
# EFB_CALL_TWIML=<Response><Say>Team Covey call alert</Say></Response>

# Webhook provider setting (used when EFB_CALL_PROVIDER=webhook)
# EFB_CALL_WEBHOOK_URL=

# Optional explicit config file location
# EFB_CONFIG_PATH=C:\ProgramData\TeamCoveyEFB\backend-config.json
